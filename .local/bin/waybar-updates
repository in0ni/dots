#!/usr/bin/env bash
set -u

readonly CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}"
readonly SOFTWARE_CACHE="$CACHE_DIR/waybar-updates.software"
readonly FIRMWARE_CACHE="$CACHE_DIR/waybar-updates.firmware"
readonly MAX_LINES=15

usage() {
  printf 'Usage: %s refresh <software|firmware|all>\n' "${0##*/}" >&2
  printf '       %s display <software|firmware>\n' "${0##*/}" >&2
  exit 1
}

count_lines() {
  [[ -n ${1:-} ]] || {
    printf '0\n'
    return
  }
  printf '%s\n' "$1" | wc -l
}

trim_lines() {
  local input=$1 count
  count=$(count_lines "$input")

  if ((count > MAX_LINES)); then
    printf '%s\n...' "$(printf '%s\n' "$input" | head -n "$MAX_LINES")"
  else
    printf '%s' "$input"
  fi
}

json_escape() {
  jq -Rsa .
}

normalize_tooltip() {
  local text=$1
  text=${text%$'\n'}
  text=${text//$'\n'/$'\r'}
  printf '%s' "$text"
}

write_cache() {
  local file=$1 tooltip=$2 alt=$3
  tooltip=$(normalize_tooltip "$tooltip")

  printf '{"tooltip":%s,"alt":%s}\n' \
    "$(printf '%s' "$tooltip" | json_escape)" \
    "$(printf '%s' "$alt" | json_escape)" >"$file"
}

read_cache() {
  local file=$1
  if [[ -f $file ]]; then
    cat "$file"
  else
    printf '{"tooltip":"cache missing","alt":"error"}\n'
  fi
}

append_block() {
  local label=$1
  local count=$2
  local body=$3

  [[ -n $body ]] || return 0

  printf '(%s) %s:\n%s\n' "$count" "$label" "$(printf '%s\n' "$body" | sed 's/^/  /')"
}

update_software() {
  local pac='' aur_updates='' svr=''
  local pac_count=0 aur_count=0 svr_count=0
  local tooltip='' alt='uptodate'

  pac=$(checkupdates --nocolor 2>/dev/null || true)
  pac_count=$(count_lines "$pac")

  if command -v aur >/dev/null 2>&1 && aur repo -d paks >/dev/null 2>&1; then
    aur_updates=$(aur repo -d paks --list 2>/dev/null | aur vercmp 2>/dev/null || true)
    aur_count=$(count_lines "$aur_updates")
  fi

  if grep -q 'srv' "$HOME/.ssh/config" 2>/dev/null; then
    svr=$(ssh srv checkupdates 2>/dev/null || true)
    svr_count=$(count_lines "$svr")
  fi

  if ((pac_count == 0 && aur_count == 0 && svr_count == 0)); then
    tooltip='Up to date'
  else
    ((pac_count > 0)) && alt='pac' || alt='nopac'
    ((aur_count > 0)) && alt+='_aur'
    ((svr_count > 0)) && alt+='_svr'

    if ((svr_count > 0)); then
      tooltip+=$(append_block "svr" "$svr_count" "$(trim_lines "$svr")")
      tooltip+=$'\n'
    fi

    if ((aur_count > 0)); then
      tooltip+=$(append_block "aur" "$aur_count" "$(trim_lines "$aur_updates")")
      tooltip+=$'\n'
    fi

    if ((pac_count > 0)); then
      tooltip+=$(append_block "pac" "$pac_count" "$(trim_lines "$pac")")
      tooltip+=$'\n'
    fi
  fi

  write_cache "$SOFTWARE_CACHE" "$tooltip" "$alt"
}

update_firmware() {
  local raw='' parsed='' count=0 tooltip='' alt='uptodate'

  fwupdmgr refresh 2>/dev/null || true
  raw=$(fwupdmgr get-updates --json 2>/dev/null || true)

  parsed=$(
    printf '%s' "$raw" | jq -r '
      [.Devices[]? as $d
        | $d.Releases[]?
        | "\($d.Name)\n   - \(.Version): \(.Summary)"
      ] | .[]
    ' 2>/dev/null || true
  )

  count=$(count_lines "$parsed")

  if ((count == 0)); then
    tooltip='Up to date'
  else
    alt='outdated'
    tooltip=$(append_block "firmware" "$count" "$(trim_lines "$parsed")")
  fi

  write_cache "$FIRMWARE_CACHE" "$tooltip" "$alt"
}

case "${1:-}" in
display)
  case "${2:-}" in
  software) read_cache "$SOFTWARE_CACHE" ;;
  firmware) read_cache "$FIRMWARE_CACHE" ;;
  *) usage ;;
  esac
  ;;
refresh)
  case "${2:-}" in
  software) update_software ;;
  firmware) update_firmware ;;
  all)
    update_software
    update_firmware
    ;;
  *) usage ;;
  esac
  ;;
*)
  usage
  ;;
esac
