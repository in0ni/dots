#!/usr/bin/env bash

[[ $(hostnamectl --static) == x* ]] || exit 0

case "${1:-}" in
get-profile)
  profile_file=/sys/firmware/acpi/platform_profile
  [[ -r $profile_file ]] || exit 0

  profile=$(<"$profile_file")

  case "$profile" in
  low-power) percentage=0 ;;
  balanced) percentage=50 ;;
  performance) percentage=100 ;;
  *) percentage=0 ;;
  esac

  printf '{"tooltip":"%s","class":"%s","percentage":%s}\n' \
    "$profile" "$profile" "$percentage"
  ;;
esac
