#!/usr/bin/env bash
#
set -u

readonly SERVICE="hyprsunset"
readonly POLL="$(sunwait poll)"

service_is_active() {
  systemctl --user is-active "$SERVICE" >/dev/null
}

toggle_service() {
  if service_is_active; then
    systemctl --user stop "$SERVICE"
  else
    systemctl --user start "$SERVICE"
  fi
}

set_temperature() {
  case "$POLL" in
  NIGHT) hyprctl hyprsunset temperature 3200 >/dev/null 2>&1 ;;
  DAY) hyprctl hyprsunset identity >/dev/null 2>&1 ;;
  *) return 1 ;;
  esac
}

waybar_json() {
  local percentage=0 status class="inactive"

  case "$POLL" in
  NIGHT) percentage=100 ;;
  DAY) percentage=0 ;;
  *)
    printf 'Usage error: sunwait poll returned "%s"\n' "$POLL" >&2
    return 1
    ;;
  esac

  if service_is_active; then
    set_temperature
    class="active"
  fi

  status=$(service_is_active && echo "active" || echo "inactive")
  tooltip="$POLL ($status)"

  # Use double-quoted JSON; this shape satisfies Waybar json return-type.
  printf '{"percentage":%d,"tooltip":"%s","class":"%s"}\n' \
    "$percentage" "$tooltip" "$class"
}

case "${1:-}" in
toggle)
  toggle_service
  ;;
waybar)
  waybar_json
  ;;
*)
  basename="${0##*/}"
  printf 'Usage: %s <toggle|waybar>\n' "$basename" >&2
  printf '  toggle  Start/stop systemd service and adjust temperature.\n' >&2
  printf '  waybar  Print Waybar JSON data.\n' >&2
  exit 1
  ;;
esac
