#!/usr/bin/env bash
set -u

readonly STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/waybar-pomodoro"
readonly STATE_FILE="$STATE_DIR/start"
readonly MINS=25
readonly POMODORO=$((MINS * 60))
readonly CHUNK=$((POMODORO / 3))

start() {
  mkdir -p "$STATE_DIR"
  date +%s >"$STATE_FILE"
}

stop() {
  rm -f "$STATE_FILE"
}

is_running() {
  [[ -f $STATE_FILE ]]
}

elapsed() {
  local start now
  start=$(<"$STATE_FILE")
  now=$(date +%s)
  printf '%s\n' "$((now - start))"
}

print_inactive() {
  printf '{"text":"○○○","tooltip":"relax :)","class":"deactivated"}\n'
}

print_status() {
  local seconds percent progress class mins_secs

  seconds=$(elapsed)

  if ((seconds >= POMODORO)); then
    progress="◉◉◉"
    class="end"
  elif ((seconds >= CHUNK * 2)); then
    progress="◉◉○"
    class="two-third"
  elif ((seconds >= CHUNK)); then
    progress="◉○○"
    class="one-third"
  else
    progress="○○○"
    class="start"
  fi

  ((seconds > POMODORO)) && seconds=$POMODORO
  percent=$((seconds * 100 / POMODORO))
  mins_secs=$(printf '%02d:%02d' $((seconds / 60)) $((seconds % 60)))

  printf '{"text":"<small>%s%%</small> %s","tooltip":"%s / %s mins","class":"%s","percentage":%s}\n' \
    "$percent" "$progress" "$mins_secs" "$MINS" "$class" "$percent"
}

case "${1:-}" in
toggle)
  if is_running; then
    stop
  else
    start
  fi
  ;;
start | vstart)
  start
  ;;
stop)
  stop
  ;;
get-time)
  if is_running; then
    print_status
  else
    print_inactive
  fi
  ;;
*)
  printf 'Usage: %s <toggle|start|stop|get-time>\n' "${0##*/}" >&2
  exit 1
  ;;
esac
